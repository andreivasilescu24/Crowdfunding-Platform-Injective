# Copy to .env.local and fill in. NEVER commit your real .env.local.

# Network: "testnet" (default) or "mainnet"
NEXT_PUBLIC_NETWORK=testnet

# Contract address — set after running `scripts/.venv/bin/python scripts/deploy.py`
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Testnet wallet mnemonic — only read by scripts/deploy.py and scripts/smoke.py.
# Never sent to the browser. Get test INJ from https://testnet.faucet.injective.network/
DEPLOYER_MNEMONIC=
